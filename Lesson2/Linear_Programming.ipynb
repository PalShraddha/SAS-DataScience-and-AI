   "source": [
    "proc optmodel;\n",
    "    var x>=0 , y>=0;\n",
    "    max z= 12*x+19*y;\n",
    "    /*Declare Constraint*/\n",
    "    con x+3*y<=225;\n",
    "    con x+y<=117;\n",
    "    con 3*x+4*y<=420;\n",
    "    solve;\n",
    "    print x y;\n",
    "quit;"
   ]
  }
